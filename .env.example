DATABASE_URL="postgresql://postgres:postgres@localhost:5433/job_search_os?schema=public"
SEED_USER_EMAIL="carl@example.com"
JOB_SEARCH_OS_USER_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Protected single-user production posture.
# Set CRON_SECRET in deployed environments. Set REQUIRE_CRON_SECRETS=true to force
# local fail-closed behavior while testing cron and sync endpoints.
CRON_SECRET=""
REQUIRE_CRON_SECRETS="false"

# Used by the MCP server when a tool needs to call dashboard API routes.
JOB_SEARCH_OS_APP_URL="http://localhost:3000"

# Optional AI provider. Without this, parsing/scoring/resume tailoring use deterministic fallbacks.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional LangSmith observability. Traces use redacted metadata by default.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="job-search-os-local"
LANGSMITH_TRACING_SAMPLING_RATE="1"
LANGCHAIN_CALLBACKS_BACKGROUND="true"

# Optional email provider. Configure either Resend or Postmark.
RESEND_API_KEY=""
POSTMARK_SERVER_TOKEN=""
NOTIFICATION_FROM_EMAIL="Job Search OS <jobs@example.com>"

# Optional inbound job-response email sync over IMAP.
# Prefer an app password or restricted mailbox credential.
JOB_EMAIL_IMAP_HOST=""
JOB_EMAIL_IMAP_PORT="993"
JOB_EMAIL_IMAP_SECURE="true"
JOB_EMAIL_IMAP_USER=""
JOB_EMAIL_IMAP_PASSWORD=""
JOB_EMAIL_IMAP_MAILBOX="INBOX"
JOB_EMAIL_IMAP_LIMIT="25"
JOB_EMAIL_IMAP_SINCE_DAYS="14"
JOB_EMAIL_IMAP_UNSEEN_ONLY="false"
EMAIL_SYNC_SECRET=""

# Optional Gmail / Outlook OAuth mailbox sync.
# Register these callback URLs with each provider:
# Gmail: http://localhost:3000/api/email/oauth/gmail/callback
# Outlook: http://localhost:3000/api/email/oauth/outlook/callback
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_REDIRECT_URI="http://localhost:3000/api/email/oauth/gmail/callback"
OUTLOOK_OAUTH_CLIENT_ID=""
OUTLOOK_OAUTH_CLIENT_SECRET=""
OUTLOOK_OAUTH_REDIRECT_URI="http://localhost:3000/api/email/oauth/outlook/callback"

# Optional LinkedIn OIDC profile connection.
# The identity callback imports profile metadata only.
# The share callback requests w_member_social for approved /linkedin-content publishing.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_OIDC_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"
LINKEDIN_SHARE_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/share/callback"
LINKEDIN_ANALYTICS_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/analytics/callback"
LINKEDIN_ANALYTICS_SYNC_SECRET=""

# Optional Pushover provider. These can also be saved on /settings.
PUSHOVER_USER_KEY=""
PUSHOVER_APP_TOKEN=""

# Optional Slack Agent Ops integration.
# Socket Mode local worker: npm run slack:dev
SLACK_BOT_TOKEN=""
SLACK_APP_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_OPS_CHANNEL_ID=""
SLACK_APPROVALS_CHANNEL_ID=""
SLACK_DECISION_LOG_CHANNEL_ID=""
SLACK_OPS_JOLENE_ID=""
SLACK_ALLOWED_USER_IDS=""
SLACK_COACH_USER_IDS=""
SLACK_LOG_LEVEL="info"

# Optional GitHub token for higher public API rate limits when syncing repo context.
GITHUB_TOKEN=""

# Optional Brave Search provider for the Search Query Backlog source.
BRAVE_SEARCH_API_KEY=""
SEARCH_QUERY_MAX_RESULTS="80"

# Optional local Chrome extension capture token.
BROWSER_EXTENSION_TOKEN=""
MARKET_INTELLIGENCE_EXTRA_SOURCES=""
MARKET_INTELLIGENCE_MAX_ARTICLES="8"

# Optional Google ADK control-plane metadata/runtime.
ADK_ENABLED="false"
ADK_MODEL="gemini-2.5-flash"

# Optional worker tuning.
EMBEDDINGS_WORKER_INTERVAL_MS="600000"
EMBEDDINGS_WORKER_BATCH_SIZE="50"
EMBEDDINGS_WORKER_BACKFILL_EVIDENCE="false"
EMBEDDINGS_WORKER_DISABLED="false"
